# ============================================================
# Lagoons Operating System — Environment Variables
# Copy this file to .env and fill in all required values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
APP_NAME="Lagoons Operating System"
APP_VERSION="1.0.0"
# true enables hot-reload, debug logging, and /api/docs exposure
DEBUG=false
# development | staging | production
ENVIRONMENT=production
# Secret used for internal signing (generate with: openssl rand -hex 32)
SECRET_KEY=replace_with_random_hex_string_at_least_32_chars

# ------------------------------------------------------------
# PostgreSQL / Supabase Database
# Use asyncpg driver: postgresql+asyncpg://user:pass@host:port/dbname
# ------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/los_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Direct Postgres connection for migrations (psycopg2 / sync)
DATABASE_SYNC_URL=postgresql://postgres:password@localhost:5432/los_db

# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=10
# Celery uses separate databases to avoid key collisions
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ------------------------------------------------------------
# Neo4j (Scientific Relationship Graph)
# ------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=replace_with_neo4j_password
# Optional: set to "neo4j+s://xxxx.databases.neo4j.io" for Aura
NEO4J_DATABASE=neo4j

# ------------------------------------------------------------
# Supabase
# ------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
# JWT secret must match the one configured in Supabase dashboard
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# ------------------------------------------------------------
# JWT (LOS-internal tokens)
# ------------------------------------------------------------
JWT_SECRET_KEY=replace_with_jwt_secret_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ------------------------------------------------------------
# AI / LLM
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
# Optional: OpenAI fallback
OPENAI_API_KEY=sk-your-openai-key-here
# Model ID to use for AI orchestration
AI_MODEL=claude-sonnet-4-6
# Max tokens per AI call
AI_MAX_TOKENS=8192
# Temperature for scientific analysis (lower = more deterministic)
AI_TEMPERATURE=0.2

# ------------------------------------------------------------
# CORS
# Comma-separated list of allowed origins
# ------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,https://app.lagoons-os.com

# ------------------------------------------------------------
# Scientific Loop Scheduling
# ------------------------------------------------------------
# How often each loop re-evaluates (minutes)
SCIENTIFIC_LOOP_INTERVAL_MINUTES=15
# How often the Decision Engine synthesises recommendations (minutes)
DECISION_ENGINE_INTERVAL_MINUTES=60
# How often the system consolidates learning (hours)
LEARNING_CYCLE_INTERVAL_HOURS=6

# ------------------------------------------------------------
# Observability
# ------------------------------------------------------------
# Sentry DSN — leave blank to disable error tracking
SENTRY_DSN=
# Prometheus metrics port
METRICS_PORT=9090
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
# Log format: json (production) | console (development)
LOG_FORMAT=json

# ------------------------------------------------------------
# Feature Flags
# ------------------------------------------------------------
# Enable real-time WebSocket push to frontend
ENABLE_WEBSOCKETS=true
# Enable automatic recommendation approval (DANGEROUS in production)
ENABLE_AUTO_APPROVE_RECOMMENDATIONS=false
# Enable HYDRUS-1D vadose zone simulation
ENABLE_VADOSE_SIMULATION=true
# Enable MODFLOW groundwater simulation
ENABLE_FLOW_SIMULATION=true
# Enable PHREEQC geochemical simulation
ENABLE_GEOCHEM_SIMULATION=true

# ------------------------------------------------------------
# Simulation Engine Paths (optional overrides)
# LOS will try to find executables on PATH if not set.
# ------------------------------------------------------------
MODFLOW_EXECUTABLE=mf6
HYDRUS_EXECUTABLE=hydrus1d
PHREEQC_EXECUTABLE=phreeqc
PEST_EXECUTABLE=pestpp-ies

# ------------------------------------------------------------
# Storage (for model files, reports, attachments)
# ------------------------------------------------------------
# local | s3 | supabase-storage
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=/data/los/storage
# Required if STORAGE_BACKEND=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=us-east-1
